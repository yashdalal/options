# Same value Kotak calls "API Access Token" / "Consumer Key"
# Neo app/web → More → TradeAPI → API Dashboard → Create Application → copy token
# Plain token only — do NOT add "Bearer "
KOTAK_ACCESS_TOKEN=
# Optional alias (either this or KOTAK_ACCESS_TOKEN is enough):
# KOTAK_CONSUMER_KEY=

KOTAK_MOBILE_NUMBER=+91XXXXXXXXXX
KOTAK_UCC=
KOTAK_MPIN=

# Optional overrides
KOTAK_LOGIN_BASE_URL=https://mis.kotaksecurities.com
KOTAK_NEO_FIN_KEY=neotradeapi
HIGHLIGHT_DEFAULT=10
SESSION_COOKIE_NAME=near_expiry_session
DEMO_MODE=false
