# Three linked Kotak Neo accounts. Labels (Prakash / Gopa / HUF) are hardcoded in the app.
# Same value Kotak calls "API Access Token" / "Consumer Key" — plain token only, no "Bearer "

KOTAK_PRAKASH_ACCESS_TOKEN=
# Optional alias:
# KOTAK_PRAKASH_CONSUMER_KEY=
KOTAK_PRAKASH_MOBILE_NUMBER=+91XXXXXXXXXX
KOTAK_PRAKASH_UCC=
KOTAK_PRAKASH_MPIN=

KOTAK_GOPA_ACCESS_TOKEN=
# KOTAK_GOPA_CONSUMER_KEY=
KOTAK_GOPA_MOBILE_NUMBER=+91XXXXXXXXXX
KOTAK_GOPA_UCC=
KOTAK_GOPA_MPIN=

KOTAK_HUF_ACCESS_TOKEN=
# KOTAK_HUF_CONSUMER_KEY=
KOTAK_HUF_MOBILE_NUMBER=+91XXXXXXXXXX
KOTAK_HUF_UCC=
KOTAK_HUF_MPIN=

# Optional overrides (shared across accounts)
KOTAK_LOGIN_BASE_URL=https://mis.kotaksecurities.com
KOTAK_NEO_FIN_KEY=neotradeapi
HIGHLIGHT_DEFAULT=10
SESSION_COOKIE_NAME=near_expiry_session

# Upstash Redis — required on Vercel so trade sessions survive across serverless instances.
# The Vercel Upstash integration sets these automatically. For local multi-instance testing,
# copy them via `vercel env pull` or paste from the Upstash console.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Aliases also accepted: KV_REST_API_URL / KV_REST_API_TOKEN
